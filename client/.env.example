# Web / iOS simulator on the same Mac can usually use 127.0.0.1.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Android emulator should use this value instead:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

# Physical phone should use your Mac LAN IP, for example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.23:8000
